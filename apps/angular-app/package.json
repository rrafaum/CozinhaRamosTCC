{
  "name": "angular-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build:css": "tailwindcss -i src/tailwind-source.css -o src/styles.css",
    "start": "concurrently \"tailwindcss -i src/tailwind-source.css -o src/styles.css --watch\" \"ng serve\"",
    "build": "npm run build:css && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "axios": "^1.16.0",
    "postcss": "^8.5.14",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
